<? xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_height="52dp"
    android:padding="1dp"
    android:layout_width="match_parent"
    android:orientation="horizontal"
    android:background="#E6D7EC"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView
        android:id="@+id/imAnhDaiDien"
        android:layout_width="50dp"
        android:backgroundColor="@color/teal_200"
        android:layout_height="50dp"/>
    <LinearLayout
        android: orientation="vertical"
        android: layout_width="match_parent"
        android: layout_height="50dp"
        android:paddingLeft="2dp">

        <TextView
            android:id="@+id/tvTenMonAnh"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:textStyle="bold"
            android:textSize="13dp"
            android:text="Món thứ nhất"/>

        <TextView
            android:id="@+id/tvDonGia"
            android:layout_width="match_parent"
            android:text="200000đ"
            android:textSize="10dp" />
        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text="Món thứ nhất"
            android:textSize="10dp"/>

    </LinearLayout>
</LinearLayout>
